# Core
DATABASE_URL=postgresql+psycopg://bookclub:bookclub@localhost:5432/bookclub
REDIS_URL=redis://localhost:6379/0
APP_ENV=dev

# LLM providers (choose one in LLM_PROVIDER)
LLM_PROVIDER=openai  # openai|claude|gemini|grok|local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
LOCAL_LLM_BASE_URL=http://localhost:11434/v1  # e.g., Ollama

# Embeddings
EMBEDDINGS_PROVIDER=openai  # openai|gemini|local
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
LOCAL_EMBEDDINGS_BASE_URL=

# TTS providers
TTS_PROVIDER=vibevoice  # vibevoice|elevenlabs|openai
TTS_BASE_URL=http://localhost:8001/v1  # OpenAI-compatible TTS proxy (VibeVoice wrapper)
TTS_MODEL=tts-1  # if using OpenAI-compatible
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Upload limits
MAX_UPLOAD_MB=200

# Local books directory for filesystem browsing (optional)
# BOOKS_DIR=/path/to/your/books

# CORS origins (comma-separated, frontend URL)
CORS_ORIGINS=http://localhost:3000

# Reranker (optional, improves retrieval quality)
# RERANKER_PROVIDER=none       # none|cohere|local
# COHERE_API_KEY=
# RERANKER_MODEL=rerank-v3.5

# Token budget guardrails (prevent runaway API costs)
# MAX_HISTORY_MESSAGES=50      # Max conversation messages sent to LLM per turn
# MAX_CONTEXT_TOKENS=4000      # Max estimated tokens of retrieved evidence per agent call
# MAX_TOKENS_PER_TURN=2048     # Max tokens requested from LLM per agent response
# MAX_SESSION_MESSAGES=200     # Max total messages in a single session
